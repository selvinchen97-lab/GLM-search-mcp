# Copy this file to `.env` and fill in your own values.
# Do not commit `.env`.

SELVIN_PROVIDER=zhipu
SELVIN_SEARCH_MODE=parallel
SELVIN_API_URL=https://open.bigmodel.cn/api/paas/v4

# Use either SELVIN_API_KEY or ZHIPU_API_KEY.
SELVIN_API_KEY=<your-api-key>
# ZHIPU_API_KEY=<your-api-key>

# Required. Put the model ID supported by your provider here.
SELVIN_MODEL=<your-model-name>

ZHIPU_SEARCH_ENGINE=search_pro
ZHIPU_SEARCH_COUNT=5
ZHIPU_CONTENT_SIZE=high
ZHIPU_SEARCH_RECENCY_FILTER=noLimit

SELVIN_MAX_TOKENS=2600
SELVIN_LOG_LEVEL=INFO

# Parallel mode tuning.
# If model-owned online search returns useful content first, the API route is
# cancelled unless it finishes within this grace window.
SELVIN_API_CANCEL_GRACE_SECONDS=0.5

# Fetch and parse URLs returned by the model-owned online-search route before
# final synthesis.
SELVIN_FETCH_ONLINE_SOURCES=true
SELVIN_FETCH_ONLINE_SOURCE_COUNT=5
SELVIN_FETCH_ONLINE_SOURCE_CHARS=3000

# For Zhipu/BigModel, model-owned online search requires passing the
# web_search tool in chat/completions. This defaults to true for bigmodel.cn.
SELVIN_ONLINE_USE_SEARCH_TOOL=true

# Optional: only needed when the model-owned online-search route uses a
# different OpenAI-compatible provider than SELVIN_API_URL / SELVIN_API_KEY.
# SELVIN_ONLINE_API_URL=<openai-compatible-api-base-url>
# SELVIN_ONLINE_API_KEY=<your-online-model-api-key>
# SELVIN_ONLINE_MODEL=<online-capable-model-name>

# Alternative: model-owned web search mode.
# Use this only with a chat model/provider that has its own online search ability.
# SELVIN_PROVIDER=custom
# SELVIN_SEARCH_MODE=model_online
# SELVIN_API_URL=<openai-compatible-api-base-url>
# SELVIN_API_KEY=<your-api-key>
# SELVIN_MODEL=<online-capable-model-name>
